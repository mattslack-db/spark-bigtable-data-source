# Copy to .env and fill in your values. Do not commit .env (it is in .gitignore).

# GCP Bigtable: project, instance, table, and region (used by notebooks, integration tests, and bundle targets).
GCP_PROJECT_ID=your-gcp-project
BIGTABLE_INSTANCE_ID=your-instance
BIGTABLE_TABLE_ID=your-table
BIGTABLE_REGION=us-central1

# Path to GCP service account JSON key (relative to project root). Used when you source .env or login.sh.
# Keep key files out of git (e.g. add gcp*.json to .gitignore).
GCP_CREDENTIALS_JSON=path/to/your-service-account-key.json

# Databricks CLI profile (used as --profile for deploy and bundle run; must match a profile in ~/.databrickscfg).
DATABRICKS_PROFILE=your-databricks-profile
# Databricks workspace URL (for auth login and .databrickscfg).
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
